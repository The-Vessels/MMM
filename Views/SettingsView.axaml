                    </ScrollViewer>
                </Border>
            </TabItem>
            <TabItem Header="Privacy">
                <Border Background="#111111">
                    <TextBox AcceptsReturn="True" Text="{Binding Description}">ffffffffffffffffffffff</TextBox>
                </Border>
            </TabItem>
            <TabItem Header="Credits">
                <Border Background="#111111">
                    <StackPanel>
                        <TextBlock>KrisGra</TextBlock>
                        <TextBlock>TooManyUsers "AnciAncientStraits" HaveThisUsername</TextBlock>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>
        <TextBlock VerticalAlignment="Bottom" Margin="10, 0, 0, 10">MMM alpha v0.1</TextBlock>
    </Grid>
</UserControl>
