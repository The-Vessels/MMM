                                <TextBlock Grid.Row="1" Grid.Column="0" FontSize="15" TextWrapping="Wrap">This is a, placeholder description, it is used to fill a section with text for testing purposes when there's no other text to put</TextBlock>
                                <ToggleButton Grid.Row="0" Grid.Column="1" Grid.RowSpan="2">
