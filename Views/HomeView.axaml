<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mmm="clr-namespace:mmm"
        x:Class="mmm.HomeView">
    <!-- <StackPanel>
        <TextBlock Text="Welcome to TestView!" />
    </StackPanel>
    <StackPanel>
        <TextBlock Text="Welcome to TestView!" />
    </StackPanel> -->
    <Border Background="#000000">
        <StackPanel>
            <Button x:Name="UsefulButton">Useful Button</Button>
            <Button>Useless Button</Button>
            <mmm:BetterProgressBar Width="300" Height="100" FontFamily="{StaticResource MainFont}">
                <!-- <mmm:BetterProgressBar.BorderPen>
                    <Pen Brush="White" LineJoin="Miter" Thickness="3" />
                </mmm:BetterProgressBar.BorderPen> -->
            </mmm:BetterProgressBar>
        </StackPanel>
    </Border>
</UserControl>
