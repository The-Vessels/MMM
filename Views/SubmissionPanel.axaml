<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="mmm.SubmissionPanel">
    <!-- <StackPanel>
        <TextBlock Text="Welcome to TestView!" />
    </StackPanel>
    <StackPanel>
        <TextBlock Text="Welcome to TestView!" />
    </StackPanel> -->
    <Border Background="#40815ac7">
      <Grid ColumnDefinitions="auto, auto">
        <StackPanel Grid.Column="0" Spacing="5">
          <Image x:Name="SubmissionThumbnail" Width="150" />
          <TextBlock Text="{Binding Name}" />
          <TextBlock Text="{Binding Submitter.Name, StringFormat='by {0}'}" />
          <StackPanel x:Name="SubmissionTags">
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="5">
            <TextBlock Text="{Binding LikeCount, StringFormat='{}{0} Likes'}" />
            <TextBlock Text="{Binding ViewCount, StringFormat='{}{0} Views'}" />
            <TextBlock Text="{Binding PostCount, StringFormat='{}{0} Posts'}" />
          </StackPanel>
          <TextBlock Text="{Binding ModelName}" />
        </StackPanel>
      </Grid>
    </Border>
</UserControl>
